{
  "name": "codebase-posters",
  "version": "0.1.1",
  "description": "Your repository as generative art — run one command, watch your codebase paint itself into a poster. 100% local, nothing leaves your machine.",
  "keywords": [
    "git",
    "generative-art",
    "visualization",
    "poster",
    "codebase",
    "data-art"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unable12/codebase-posters"
  },
  "homepage": "https://github.com/unable12/codebase-posters",
  "private": false,
  "type": "module",
  "bin": {
    "codebase-posters": "bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:server",
    "build:server": "esbuild server/standalone.ts --bundle --platform=node --format=esm --outfile=dist/server.mjs",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "esbuild": "^0.25.0",
    "fflate": "^0.8.2",
    "mp4-muxer": "^5.2.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.23.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
